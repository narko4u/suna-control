# Suna Control Plane — Environment Variables
# Copy this file to .env and fill in your values

# HMAC shared secret for signing agent commands
SHARED_SECRET=your_strong_secret_here

# GitHub webhook secret (set in GitHub repo settings)
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here

# SQLite database path (default: control.db)
DB_PATH=control.db
